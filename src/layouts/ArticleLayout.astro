---
import { render, type CollectionEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import type { Lang } from '@/i18n/ui';
import { useTranslations } from '@/i18n/utils';
import { tagLabels, tagPath } from '@/i18n/tags';

interface Props {
  post: CollectionEntry<'blog'>;
  lang: Lang;
  altLangHref?: string | null;
}

const { post, lang, altLangHref } = Astro.props;
const t = useTranslations(lang);
const { Content } = await render(post);
const key = post.data.translationKey;

const locale = lang === 'es' ? 'es-ES' : 'en-US';
const dateLabel = new Intl.DateTimeFormat(locale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(post.data.publishedAt);

const words = post.body?.trim().split(/\s+/).length ?? 0;
const minutes = Math.max(1, Math.round(words / 200));
const readingLabel =
  lang === 'es' ? `${minutes} min de lectura` : `${minutes} min read`;

const initial = 'E';
const bylineAuthor =
  lang === 'es' ? 'Por Elias Ablan' : 'By Elias Ablan';
const bylineCity = 'Caracas';
const tags = post.data.tags ?? [];
---

<BaseLayout
  title={`${post.data.title} — Elias Ablan`}
  description={post.data.description}
  altLangHref={altLangHref}
>
  <article class="article">
    <p class="eyebrow">
      {
        tags[0] && (
          <>
            <a href={tagPath(lang, tags[0])} class="tag-link">{tagLabels[tags[0]][lang]}</a>
            <span class="sep">·</span>
          </>
        )
      }
      <span>{readingLabel}</span>
      <span class="sep">·</span>
      <time datetime={post.data.publishedAt.toISOString()}>{dateLabel}</time>
    </p>

    <h1 class="article-h1" transition:name={`post-${key}-title`}>
      {post.data.title}
    </h1>

    <p class="lede">
      <span transition:name={`post-${key}-description`}
        >{post.data.description}</span
      >
    </p>

    <div class="byline">
      <span class="avatar" aria-hidden="true">{initial}</span>
      <span class="meta">
        {bylineAuthor} <span class="dot-sep">·</span>
        {bylineCity}
      </span>
    </div>

    <div class="article-body">
      <Content />
    </div>

    {
      tags.length > 0 && (
        <div class="article-footer">
          <div class="tags">
            {tags.map((tg) => (
              <a class="tag" href={tagPath(lang, tg)}>
                {tagLabels[tg][lang]}
              </a>
            ))}
          </div>
          <div class="fin">~ {lang === 'es' ? 'FIN' : 'END'} ~</div>
        </div>
      )
    }

    <p class="back">
      <a href={`/${lang}/blog`}>{t('blog.back')}</a>
    </p>
  </article>
</BaseLayout>

<style>
  .article {
    max-width: 680px;
    margin: 0 auto;
    padding: 64px 32px 96px;
  }
  @media (max-width: 600px) {
    .article {
      padding: 40px 20px 64px;
    }
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--tx-secondary);
    margin: 0 0 24px;
    line-height: 1.4;
  }
  .eyebrow .sep {
    opacity: 0.5;
    margin: 0 8px;
  }
  .eyebrow .tag-link {
    color: inherit;
    text-decoration: none;
  }
  .eyebrow .tag-link:hover {
    color: var(--accent);
  }

  .article-h1 {
    font-family: var(--font-serif);
    font-size: clamp(36px, 5vw, 52px);
    font-weight: 600;
    letter-spacing: -0.018em;
    line-height: 1.08;
    margin: 0 0 24px;
    color: var(--tx);
    text-wrap: balance;
  }

  .lede {
    font-size: 22px;
    line-height: 1.4;
    font-style: italic;
    font-weight: 400;
    color: var(--tx-secondary);
    margin: 0 0 32px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--rule);
    text-wrap: pretty;
  }

  .byline {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 48px;
  }
  .byline .avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--accent);
    color: var(--on-accent);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 14px;
    font-weight: 600;
    flex-shrink: 0;
  }
  .byline .meta {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--tx-secondary);
  }
  .byline .dot-sep {
    opacity: 0.5;
    margin: 0 6px;
  }

  .article-footer {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--rule);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }
  .tags {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.02em;
    background: var(--bg-secondary);
    border: 1px solid var(--rule);
    border-radius: 999px;
    padding: 3px 10px;
    color: var(--tx-secondary);
    text-decoration: none;
  }
  .tag:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  .fin {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    color: var(--tx-muted);
  }

  .back {
    margin-top: 48px;
    font-family: var(--font-serif);
    font-size: 16px;
  }
</style>
