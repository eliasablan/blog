---
import { getCollection, type CollectionEntry } from 'astro:content';
import ArticleLayout from '@/layouts/ArticleLayout.astro';
import { splitEntryId, getTranslatedEntry, filterByLang } from '@/i18n/utils';
import { entryPath } from '@/i18n/routes';

export async function getStaticPaths() {
  const lang = 'es' as const;
  const posts = filterByLang(await getCollection('blog'), lang).filter(
    (p) => !p.data.draft,
  );
  return posts.map((post) => ({
    params: { slug: splitEntryId(post.id).slug },
    props: { post },
  }));
}

const { post } = Astro.props as { post: CollectionEntry<'blog'> };
const lang = 'es' as const;

const translated = await getTranslatedEntry('blog', post, 'en');
const altUrl = translated
  ? entryPath('en', 'blog', splitEntryId(translated.id).slug)
  : null;
---

<ArticleLayout post={post} lang={lang} altLangHref={altUrl} />
