---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import { useTranslations, filterByLang, type Lang } from '@/i18n/utils';
import { tagSlugs, tagLabels, type TagSlug } from '@/i18n/tags';

export function getStaticPaths() {
  const langs: Lang[] = ['en', 'es'];
  return langs.flatMap((lang) =>
    tagSlugs.map((tag) => ({
      params: { lang, tag },
      props: { tag },
    })),
  );
}

const lang = Astro.params.lang as Lang;
const { tag } = Astro.props as { tag: TagSlug };
const t = useTranslations(lang);
const label = tagLabels[tag][lang];

const posts = filterByLang(await getCollection('blog'), lang)
  .filter((p) => !p.data.draft && p.data.tags.includes(tag))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const projects = filterByLang(await getCollection('portfolio'), lang)
  .filter((p) => p.data.tags.includes(tag))
  .sort((a, b) => b.data.year - a.data.year);

const isEmpty = posts.length === 0 && projects.length === 0;
---

<BaseLayout title={`${label} — Elías Ablán`} description={label}>
  <section class="mx-auto max-w-3xl px-4 py-12">
    <header class="mb-10 space-y-2">
      <p class="tag-eyebrow">{t('tags.eyebrow')}</p>
      <h1 class="text-4xl font-bold tracking-tight">{label}</h1>
    </header>

    {isEmpty && <p class="text-muted-foreground">{t('tags.empty')}</p>}

    {
      posts.length > 0 && (
        <div class="group">
          <h2 class="group-title">{t('tags.articles')}</h2>
          <ul class="flex flex-col gap-6">
            {posts.map((post) => (
              <li>
                <PostCard post={post} lang={lang} />
              </li>
            ))}
          </ul>
        </div>
      )
    }

    {
      projects.length > 0 && (
        <div class="group">
          <h2 class="group-title">{t('tags.projects')}</h2>
          <ul class="flex flex-col gap-6">
            {projects.map((project) => (
              <li>
                <ProjectCard project={project} lang={lang} />
              </li>
            ))}
          </ul>
        </div>
      )
    }

    <p class="back">
      <a href={`/${lang}/`}>{t('tags.back')}</a>
    </p>
  </section>
</BaseLayout>

<style>
  .tag-eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--tx-muted);
  }
  .group {
    margin-top: 40px;
  }
  .group-title {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--tx-muted);
    margin: 0 0 16px;
  }
  .back {
    margin-top: 48px;
    font-family: var(--font-serif);
    font-size: 16px;
  }
</style>
