---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { useTranslations, filterByLang, type Lang } from "@/i18n/utils";
import { tagSlugs, tagLabels, type TagSlug } from "@/i18n/tags";
import {
  isPublished,
  sortPostsByRecent,
  sortProjectsByRecent,
} from "@/lib/content";

export async function getStaticPaths() {
  const langs: Lang[] = ["en", "es"];
  const posts = await getCollection("blog");
  const projects = await getCollection("portfolio");

  return langs.flatMap((lang) => {
    const langPosts = filterByLang(posts, lang).filter(isPublished);
    const langProjects = filterByLang(projects, lang).filter(isPublished);

    return tagSlugs
      .filter(
        (tag) =>
          langPosts.some((post) => post.data.tags.includes(tag)) ||
          langProjects.some((project) => project.data.tags.includes(tag)),
      )
      .map((tag) => ({
        params: { lang, tag },
        props: { tag },
      }));
  });
}

const lang = Astro.params.lang as Lang;
const { tag } = Astro.props as { tag: TagSlug };
const t = useTranslations(lang);
const label = tagLabels[tag][lang];

const posts = filterByLang(await getCollection("blog"), lang)
  .filter((p) => isPublished(p) && p.data.tags.includes(tag))
  .sort(sortPostsByRecent);

const projects = filterByLang(await getCollection("portfolio"), lang)
  .filter((p) => isPublished(p) && p.data.tags.includes(tag))
  .sort(sortProjectsByRecent);

const isEmpty = posts.length === 0 && projects.length === 0;

const eyebrowClasses =
  "font-mono text-xs tracking-[0.08em] text-tx-muted uppercase";
---

<BaseLayout title={`${label} — Elías Ablán`} description={label}>
  <section class="mx-auto max-w-3xl px-4 py-12">
    <header class="mb-10 space-y-2">
      <p class={eyebrowClasses}>{t("tags.eyebrow")}</p>
      <h1 class="text-4xl font-bold tracking-tight">{label}</h1>
    </header>

    {isEmpty && <p class="text-muted-foreground">{t("tags.empty")}</p>}

    {
      posts.length > 0 && (
        <div class="mt-10">
          <h2 class={`${eyebrowClasses} m-0 mb-4`}>{t("tags.articles")}</h2>
          <ul class="flex flex-col gap-6">
            {posts.map((post) => (
              <li>
                <PostCard post={post} lang={lang} />
              </li>
            ))}
          </ul>
        </div>
      )
    }

    {
      projects.length > 0 && (
        <div class="mt-10">
          <h2 class={`${eyebrowClasses} m-0 mb-4`}>{t("tags.projects")}</h2>
          <ul class="flex flex-col gap-6">
            {projects.map((project) => (
              <li>
                <ProjectCard project={project} lang={lang} />
              </li>
            ))}
          </ul>
        </div>
      )
    }

    <p class="mt-12 font-serif text-base">
      <a href={`/${lang}/`}>{t("tags.back")}</a>
    </p>
  </section>
</BaseLayout>
