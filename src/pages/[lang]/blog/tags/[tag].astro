---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import { filterByLang, type Lang } from '@/i18n/utils';

export async function getStaticPaths() {
  const all = await getCollection('blog');
  const langs: Lang[] = ['en', 'es'];
  return langs.flatMap((lang) => {
    const posts = filterByLang(all, lang).filter((p) => !p.data.draft);
    const tagSet = new Set(posts.flatMap((p) => p.data.tags));
    return [...tagSet].map((tag) => ({
      params: { lang, tag },
      props: {
        tag,
        posts: posts
          .filter((p) => p.data.tags.includes(tag))
          .sort(
            (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
          ),
      },
    }));
  });
}

const lang = Astro.params.lang as Lang;
const { tag, posts } = Astro.props;

const labels = {
  es: {
    eyebrow: 'Etiqueta',
    description: `Artículos sobre ${tag}.`,
    count: `${posts.length} artículo${posts.length !== 1 ? 's' : ''}`,
    back: '← Volver al blog',
  },
  en: {
    eyebrow: 'Tag',
    description: `Articles about ${tag}.`,
    count: `${posts.length} article${posts.length !== 1 ? 's' : ''}`,
    back: '← Back to blog',
  },
}[lang];
---

<BaseLayout title={`#${tag} — Blog — Elías Ablán`} description={labels.description}>
  <section class="mx-auto max-w-3xl px-4 py-12">
    <header class="mb-10 space-y-2">
      <p class="tag-eyebrow">{labels.eyebrow}</p>
      <h1 class="text-4xl font-bold tracking-tight">#{tag}</h1>
      <p class="text-muted-foreground">{labels.count}</p>
    </header>

    <ul class="flex flex-col gap-6">
      {posts.map((post) => (
        <li>
          <PostCard post={post} lang={lang} />
        </li>
      ))}
    </ul>

    <p class="back">
      <a href={`/${lang}/blog`}>{labels.back}</a>
    </p>
  </section>
</BaseLayout>

<style>
  .tag-eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--tx-muted);
  }
  .back {
    margin-top: 48px;
    font-family: var(--font-serif);
    font-size: 16px;
  }
</style>
