---
import type { CollectionEntry } from 'astro:content';
import type { Lang } from '@/i18n/ui';
import { splitEntryId } from '@/i18n/utils';
import { sectionPath } from '@/i18n/routes';

interface Props {
  post: CollectionEntry<'blog'>;
  lang: Lang;
}

const { post, lang } = Astro.props;
const { slug } = splitEntryId(post.id);
const href = `${sectionPath(lang, 'blog')}/${slug}`;
const key = post.data.translationKey;

const monthsEs = ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'];
const monthsEn = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
const months = lang === 'es' ? monthsEs : monthsEn;
const d = post.data.publishedAt;
const dateLabel = `${d.getUTCFullYear()} · ${months[d.getUTCMonth()]}`;
---

<div class="post">
  <time
    class="date"
    datetime={post.data.publishedAt.toISOString()}
    transition:name={`post-${key}-date`}>{dateLabel}</time
  >
  <div>
    <a href={href} class="post-title" transition:name={`post-${key}-title`}>
      {post.data.title}
    </a>
    <p class="post-lede">
      <span transition:name={`post-${key}-description`}
        >{post.data.description}</span
      >
    </p>
  </div>
</div>

<style>
  .post {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 16px;
    align-items: baseline;
  }
  .date {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--tx-muted);
    letter-spacing: 0.04em;
    padding-top: 5px;
  }
  .post-title {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 19px;
    line-height: 1.3;
    color: var(--tx);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--tx) 20%, transparent);
    text-underline-offset: 4px;
  }
  .post-title:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }
  .post-lede {
    font-size: 16px;
    color: var(--tx-secondary);
    line-height: 1.5;
    margin: 4px 0 0;
  }
  @media (max-width: 600px) {
    .post {
      grid-template-columns: 1fr;
      gap: 2px;
    }
    .date {
      padding-top: 0;
    }
  }
</style>
