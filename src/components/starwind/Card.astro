---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'div'> {
  /** When true, applies hover lift effect. */
  hover?: boolean;
}

const { class: className, hover = false, ...rest } = Astro.props;
---

<div
  class:list={[
    'rounded-lg border border-border bg-card text-card-foreground shadow-sm overflow-hidden',
    hover && 'transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md',
    className,
  ]}
  {...rest}
>
  <slot />
</div>
