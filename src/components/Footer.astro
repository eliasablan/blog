---
import type { Lang } from '@/i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="left">
    © {year} Elias Ablan <span class="sep">·</span> Caracas
  </div>
  <div class="right">
    <a href={`/${lang}/rss.xml`} aria-label="RSS">RSS</a>
    <span class="sep">·</span>
    <a
      href="https://github.com/eliasablan"
      target="_blank"
      rel="noopener noreferrer">GitHub</a
    >
    <span class="sep">·</span>
    <a href={`/${lang}/`}>{lang === 'es' ? 'Inicio' : 'Home'}</a>
  </div>
</footer>

<style>
  .site-footer {
    view-transition-name: site-footer;
    max-width: 680px;
    margin: 0 auto;
    padding: 32px 32px 48px;
    border-top: 1px solid var(--rule);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--tx-muted);
    letter-spacing: 0.02em;
    flex-wrap: wrap;
    gap: 12px;
  }
  .site-footer a {
    color: var(--tx-secondary);
    text-decoration: none;
  }
  .site-footer a:hover {
    color: var(--accent);
  }
  .site-footer .right {
    display: inline-flex;
    gap: 8px;
    align-items: center;
  }
  .site-footer .sep {
    color: var(--tx-muted);
    opacity: 0.6;
  }
  @media (max-width: 600px) {
    .site-footer {
      padding: 32px 20px;
    }
  }
</style>
