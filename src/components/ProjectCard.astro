---
import type { CollectionEntry } from 'astro:content';
import type { Lang } from '@/i18n/ui';
import { splitEntryId } from '@/i18n/utils';
import { sectionPath } from '@/i18n/routes';

interface Props {
  project: CollectionEntry<'portfolio'>;
  lang: Lang;
}

const { project, lang } = Astro.props;
const { slug } = splitEntryId(project.id);
const href = `${sectionPath(lang, 'portfolio')}/${slug}`;
const key = project.data.translationKey;

const repoLabel = lang === 'es' ? 'código' : 'code';
const demoLabel = lang === 'es' ? 'visitar' : 'visit';
---

<div class="project">
  <div class="year" transition:name={`project-${key}-year`}>
    {project.data.year}
  </div>
  <div class="body">
    <a href={href} class="title" transition:name={`project-${key}-title`}>
      {project.data.title}
    </a>
    <p class="desc">
      <span transition:name={`project-${key}-description`}
        >{project.data.description}</span
      >
    </p>
    {
      project.data.tech.length > 0 && (
        <p class="stack">
          {project.data.tech.map((t, i) => (
            <>
              <span>{t}</span>
              {i < project.data.tech.length - 1 && <span class="sep">·</span>}
            </>
          ))}
        </p>
      )
    }
  </div>
  <div class="actions">
    {
      project.data.demo && (
        <a href={project.data.demo} target="_blank" rel="noopener">
          <svg viewBox="0 0 16 16" aria-hidden="true">
            <path
              d="M5 11L11 5M11 5H6.5M11 5V9.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
          {demoLabel}
        </a>
      )
    }
    {
      project.data.repo && (
        <a href={project.data.repo} target="_blank" rel="noopener">
          <svg viewBox="0 0 16 16" aria-hidden="true">
            <path
              d="M3.5 8c0-1.66 1.34-3 3-3h1m4 6c0 1.66-1.34 3-3 3h-1M6.5 8h5"
              stroke-linecap="round"
            />
          </svg>
          {repoLabel}
        </a>
      )
    }
  </div>
</div>

<style>
  .project {
    display: grid;
    grid-template-columns: 60px 1fr auto;
    gap: 16px;
    align-items: baseline;
  }
  .year {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--tx-muted);
    letter-spacing: 0.04em;
    padding-top: 6px;
  }
  .body {
    min-width: 0;
  }
  .title {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 22px;
    line-height: 1.25;
    letter-spacing: -0.008em;
    color: var(--tx);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--tx) 20%, transparent);
    text-underline-offset: 4px;
    display: inline;
  }
  .title:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }
  .desc {
    font-size: 17px;
    color: var(--tx-secondary);
    line-height: 1.5;
    margin: 6px 0 8px;
    max-width: 56ch;
  }
  .stack {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--tx-muted);
    line-height: 1.5;
    margin: 0;
  }
  .stack .sep {
    margin: 0 6px;
    opacity: 0.7;
  }
  .actions {
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-items: flex-end;
    padding-top: 8px;
  }
  .actions a {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.02em;
    color: var(--tx-secondary);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    white-space: nowrap;
  }
  .actions a:hover {
    color: var(--accent);
  }
  .actions svg {
    width: 11px;
    height: 11px;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.5;
  }
  @media (max-width: 600px) {
    .project {
      grid-template-columns: 1fr;
      gap: 4px;
    }
    .year {
      padding-top: 0;
    }
    .actions {
      flex-direction: row;
      gap: 16px;
      align-items: flex-start;
      padding-top: 4px;
    }
  }
</style>
