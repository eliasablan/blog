---
import type { CollectionEntry } from "astro:content";
import type { Lang } from "@/i18n/ui";
import { splitEntryId } from "@/i18n/utils";
import { sectionPath } from "@/i18n/routes";
import { tagLabels, tagPath } from "@/i18n/tags";

interface Props {
    project: CollectionEntry<"portfolio">;
    lang: Lang;
}

const { project, lang } = Astro.props;
const { slug } = splitEntryId(project.id);
const href = `${sectionPath(lang, "portfolio")}/${slug}`;
const key = project.data.translationKey;

const repoLabel = lang === "es" ? "código" : "code";
const demoLabel = lang === "es" ? "visitar" : "visit";
---

<div
    class="grid grid-cols-[60px_1fr_auto] items-baseline gap-4 max-[600px]:grid-cols-1 max-[600px]:gap-1"
>
    <div
        class="pt-1.5 font-mono text-xs tracking-[0.04em] text-tx-muted max-[600px]:pt-0"
        transition:name={`project-${key}-year`}
    >
        {project.data.year}
    </div>
    <div class="min-w-0">
        <a
            href={href}
            class="inline font-serif text-[22px] font-semibold leading-tight tracking-[-0.008em] text-foreground underline decoration-foreground/20 underline-offset-4 hover:text-primary hover:decoration-primary"
            transition:name={`project-${key}-title`}
        >
            {project.data.title}
        </a>
        <p
            class="mt-1.5 mb-2 max-w-[56ch] text-[17px] leading-normal text-tx-secondary"
        >
            <span transition:name={`project-${key}-description`}
                >{project.data.description}</span
            >
        </p>
        {
            project.data.tags.length > 0 && (
                <p class="m-0 font-mono text-xs leading-normal text-tx-muted">
                    {project.data.tags.map((tag, i) => (
                        <>
                            <a
                                href={tagPath(lang, tag)}
                                class="text-inherit underline decoration-tx-muted/30 hover:text-primary hover:decoration-primary"
                            >
                                {tagLabels[tag][lang]}
                            </a>
                            {i < project.data.tags.length - 1 && (
                                <span class="mx-1.5 opacity-70">·</span>
                            )}
                        </>
                    ))}
                </p>
            )
        }
    </div>
    <div
        class="flex flex-col items-end gap-1.5 pt-2 max-[600px]:flex-row max-[600px]:items-start max-[600px]:gap-4 max-[600px]:pt-1"
    >
        {
            project.data.demo && (
                <a
                    href={project.data.demo}
                    target="_blank"
                    rel="noopener"
                    class="inline-flex items-center gap-1.25 font-mono text-xs tracking-[0.02em] whitespace-nowrap text-tx-secondary no-underline hover:text-primary"
                >
                    <svg
                        viewBox="0 0 16 16"
                        aria-hidden="true"
                        class="block h-2.75 w-2.75 fill-none stroke-current stroke-[1.5]"
                    >
                        <path
                            d="M5 11L11 5M11 5H6.5M11 5V9.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        />
                    </svg>
                    {demoLabel}
                </a>
            )
        }
        {
            project.data.repo && (
                <a
                    href={project.data.repo}
                    target="_blank"
                    rel="noopener"
                    class="inline-flex items-center gap-1.25 font-mono text-xs tracking-[0.02em] whitespace-nowrap text-tx-secondary no-underline hover:text-primary"
                >
                    <svg
                        viewBox="0 0 16 16"
                        aria-hidden="true"
                        class="block h-2.75 w-2.75 fill-none stroke-current stroke-[1.5]"
                    >
                        <path
                            d="M3.5 8c0-1.66 1.34-3 3-3h1m4 6c0 1.66-1.34 3-3 3h-1M6.5 8h5"
                            stroke-linecap="round"
                        />
                    </svg>
                    {repoLabel}
                </a>
            )
        }
    </div>
</div>
