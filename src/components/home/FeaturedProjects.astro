---
import { getCollection } from "astro:content";
import type { Lang } from "@/i18n/ui";
import { filterByLang, useTranslations } from "@/i18n/utils";
import { isPublished, sortProjectsByRecent } from "@/lib/content";
import ProjectCard from "@/components/ProjectCard.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const projects = filterByLang(await getCollection("portfolio"), lang)
  .filter((p) => isPublished(p) && p.data.featured)
  .sort(sortProjectsByRecent)
  .slice(0, 5);
---

{
  projects.length > 0 && (
    <section class="mx-auto max-w-170 px-8 max-[600px]:px-5">
      <h2 class="mt-16 mb-5 scroll-mt-20 font-serif text-[32px] leading-[1.2] font-semibold tracking-[-0.012em] text-foreground before:mr-3 before:font-normal before:text-primary before:not-italic before:opacity-85 before:content-['§']">
        {t("home.featured.portfolio.title")}
      </h2>
      <div class="flex flex-col gap-8">
        {projects.map((project) => (
          <ProjectCard project={project} lang={lang} />
        ))}
      </div>
      <hr class="mt-16 h-px w-full border-0 bg-rule" />
    </section>
  )
}
