---
import type { Lang } from '@/i18n/ui';
import { useTranslations } from '@/i18n/utils';
import { tagSlugs, tagLabels, tagPath } from '@/i18n/tags';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="section-shell">
  <h2 class="section">{t('topics.title')}</h2>
  <p class="themes-intro">{t('topics.intro')}</p>
  <p class="tag-list">
    {
      tagSlugs.map((slug, i) => (
        <>
          <a href={tagPath(lang, slug)}>{tagLabels[slug][lang]}</a>
          {i < tagSlugs.length - 1 && <span class="sep">·</span>}
        </>
      ))
    }
  </p>
</section>

<style>
  .themes-intro {
    font-size: 18px;
    margin: 0 0 24px;
    color: var(--tx);
  }
  .tag-list {
    font-family: var(--font-mono);
    font-size: 14px;
    line-height: 2;
    color: var(--tx-secondary);
    margin: 0;
  }
  .tag-list a {
    color: var(--tx);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--tx) 25%, transparent);
  }
  .tag-list a:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }
  .tag-list .sep {
    color: var(--tx-muted);
    margin: 0 8px;
    user-select: none;
  }
</style>
