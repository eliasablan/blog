---
import type { Lang } from "@/i18n/ui";
import { useTranslations } from "@/i18n/utils";
import { tagSlugs, tagLabels, tagPath } from "@/i18n/tags";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="mx-auto max-w-170 px-8 max-[600px]:px-5">
  <h2
    class="mt-16 mb-5 scroll-mt-20 font-serif text-[32px] leading-[1.2] font-semibold tracking-[-0.012em] text-foreground before:mr-3 before:font-normal before:text-primary before:not-italic before:opacity-85 before:content-['§']"
  >
    {t("topics.title")}
  </h2>
  <p class="m-0 mb-6 text-lg text-foreground">{t("topics.intro")}</p>
  <p class="m-0 font-mono text-sm leading-loose text-tx-secondary">
    {
      tagSlugs.map((slug, i) => (
        <>
          <a
            href={tagPath(lang, slug)}
            class="text-foreground underline decoration-foreground/25 hover:text-primary hover:decoration-primary"
          >
            {tagLabels[slug][lang]}
          </a>
          {i < tagSlugs.length - 1 && (
            <span class="mx-2 text-tx-muted select-none">·</span>
          )}
        </>
      ))
    }
  </p>
</section>
