---
import type { Lang } from '@/i18n/ui';
import { useTranslations } from '@/i18n/utils';
import { sectionPath } from '@/i18n/routes';
import Button from '@/components/starwind/Button.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="mx-auto max-w-3xl px-4 pb-12 pt-20">
  <p class="font-mono text-xs uppercase tracking-widest text-muted-foreground">
    {t('home.hero.eyebrow')}
  </p>
  <h1 class="mt-3 text-5xl font-bold tracking-tight sm:text-6xl">
    Elías Ablán
  </h1>
  <p class="mt-6 max-w-xl text-lg text-muted-foreground">
    {
      lang === 'es'
        ? 'Construyo productos web rápidos y bien diseñados. Aquí escribo sobre lo que aprendo y muestro proyectos en los que trabajo.'
        : 'I build fast, well-designed web products. I write here about what I learn and showcase the projects I work on.'
    }
  </p>
  <div class="mt-8 flex flex-wrap gap-3">
    <Button href={sectionPath(lang, 'blog')} variant="primary">
      {t('home.hero.cta.posts')}
    </Button>
    <Button href={sectionPath(lang, 'portfolio')} variant="outline">
      {t('home.hero.cta.portfolio')}
    </Button>
  </div>
</section>
