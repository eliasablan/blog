---
import type { Lang } from '@/i18n/ui';
import ContactEs from '@/content/home/contact.es.mdx';
import ContactEn from '@/content/home/contact.en.mdx';
import ContactForm from '@/components/ContactForm.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const Content = lang === 'es' ? ContactEs : ContactEn;
const title = lang === 'es' ? 'Contacto' : 'Contact';
---

<section id="contact" class="section-shell">
  <h2 class="section">{title}</h2>
  <div class="contact-prose">
    <Content />
  </div>
  <ContactForm lang={lang} />
</section>

<style>
  .contact-prose :global(p) {
    font-size: 18px;
    line-height: 1.7;
    margin: 0 0 48px;
    color: var(--tx);
  }
  .contact-prose :global(a) {
    color: var(--accent);
  }
</style>
