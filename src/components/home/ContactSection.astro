---
import type { Lang } from '@/i18n/ui';
import ContactEs, { frontmatter as fmEs } from '@/content/home/contact.es.mdx';
import ContactEn, { frontmatter as fmEn } from '@/content/home/contact.en.mdx';
import ContactForm from '@/components/ContactForm.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const Content = lang === 'es' ? ContactEs : ContactEn;
const { headline } = lang === 'es' ? fmEs : fmEn;
---

<section id="contact" class="mx-auto max-w-3xl px-4 py-16">
  <h2 class="mb-4 text-3xl font-bold tracking-tight">{headline}</h2>
  <div class="prose prose-neutral dark:prose-invert mb-8 max-w-none">
    <Content />
  </div>

  <div class="mb-8 flex flex-wrap gap-4 text-sm">
    <a
      href="mailto:eliasablan93@gmail.com"
      class="inline-flex items-center gap-2 text-muted-foreground hover:text-foreground"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="2" y="4" width="20" height="16" rx="2" />
        <path d="m22 7-10 5L2 7" />
      </svg>
      eliasablan93@gmail.com
    </a>
    <a
      href="https://github.com/eliasablan"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 text-muted-foreground hover:text-foreground"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 .5C5.7.5.5 5.7.5 12c0 5 3.3 9.3 7.8 10.8.6.1.8-.2.8-.6v-2.1c-3.2.7-3.9-1.5-3.9-1.5-.5-1.4-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.6-.3-5.3-1.3-5.3-5.8 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.2 1.2.9-.3 1.9-.4 2.9-.4s2 .1 2.9.4c2.2-1.5 3.2-1.2 3.2-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.9 1.2 3.1 0 4.5-2.7 5.5-5.3 5.8.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.5-1.5 7.8-5.8 7.8-10.8C23.5 5.7 18.3.5 12 .5z"/>
      </svg>
      github.com/eliasablan
    </a>
  </div>

  <ContactForm lang={lang} />
</section>
