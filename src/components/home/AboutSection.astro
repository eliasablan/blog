---
import type { Lang } from '@/i18n/ui';
import AboutEs from '@/content/home/about.es.mdx';
import AboutEn from '@/content/home/about.en.mdx';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const Content = lang === 'es' ? AboutEs : AboutEn;
---

<section id="about" class="about">
  <div class="prose">
    <Content />
  </div>
  <hr class="intro-rule" />
</section>

<style>
  .about {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .about .prose :global(p) {
    font-size: 18px;
    line-height: 1.7;
    margin: 0 0 24px;
    color: var(--tx);
  }
  .about .prose :global(p:last-child) {
    margin-bottom: 0;
  }
  .about .prose :global(strong) {
    font-weight: 600;
  }
  .about .prose :global(em) {
    font-style: italic;
  }
  .about .prose :global(a) {
    color: var(--accent);
  }
  .intro-rule {
    border: 0;
    height: 1px;
    background: var(--rule);
    width: 60px;
    margin: 48px auto 0;
  }
  @media (max-width: 600px) {
    .about {
      padding: 0 20px;
    }
  }
</style>
