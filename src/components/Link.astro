---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'a'> {
  href: string;
}

const { href, class: className, ...rest } = Astro.props;

// External = absolute URL whose host differs from the current site.
// At build time Astro.site might be undefined, so anything starting with http(s)
// that is not explicitly relative is treated as external by default.
const isExternal = /^https?:\/\//i.test(href);
const externalAttrs = isExternal
  ? { target: '_blank', rel: 'noopener noreferrer' }
  : {};
---

<a href={href} class={className} {...externalAttrs} {...rest}>
  <slot />
</a>
