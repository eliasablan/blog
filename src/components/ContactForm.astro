---
import type { Lang } from '@/i18n/ui';
import { useTranslations } from '@/i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<form id="contact-form" class="contact-form" novalidate>
  <div class="row">
    <div class="field">
      <label for="contact-name">
        {t('contact.form.name')} <span class="req">*</span>
      </label>
      <input
        id="contact-name"
        name="name"
        type="text"
        required
        autocomplete="name"
        placeholder={lang === 'es' ? 'Cómo te llamas' : 'Your name'}
      />
      <p data-error-for="name" class="error hidden"></p>
    </div>
    <div class="field">
      <label for="contact-email">
        {t('contact.form.email')} <span class="req">*</span>
      </label>
      <input
        id="contact-email"
        name="email"
        type="email"
        required
        autocomplete="email"
        placeholder={lang === 'es' ? 'tu@correo.com' : 'you@email.com'}
      />
      <p data-error-for="email" class="error hidden"></p>
    </div>
  </div>

  <div class="field">
    <label for="contact-subject">{t('contact.form.subject')}</label>
    <input
      id="contact-subject"
      name="subject"
      type="text"
      placeholder={lang === 'es' ? 'De qué se trata' : 'What is it about'}
    />
  </div>

  <div class="field">
    <label for="contact-message">
      {t('contact.form.message')} <span class="req">*</span>
    </label>
    <textarea
      id="contact-message"
      name="message"
      required
      rows="6"
      minlength="10"
      placeholder={lang === 'es'
        ? 'Cuéntame brevemente de qué se trata.'
        : 'Tell me briefly what it is about.'}></textarea>
    <p data-error-for="message" class="error hidden"></p>
  </div>

  {/* Honeypot */}
  <div aria-hidden="true" class="honeypot" tabindex="-1">
    <label>
      Website (do not fill)
      <input type="text" name="website" tabindex="-1" autocomplete="off" />
    </label>
  </div>

  <div class="submit-row">
    <button type="submit" class="submit">
      <span data-submit-label>{t('contact.form.submit')}</span>
      <span data-submitting-label class="hidden"
        >{t('contact.form.submitting')}</span
      >
    </button>
    <p
      data-status="success"
      class="feedback feedback-success hidden"
    >{t('contact.form.success')}</p>
    <p
      data-status="error"
      class="feedback feedback-error hidden"
    >{t('contact.form.error')}</p>
  </div>
</form>

<style>
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  @media (min-width: 640px) {
    .row {
      grid-template-columns: 1fr 1fr;
    }
  }
  .field {
    display: flex;
    flex-direction: column;
  }
  .field label {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--tx-secondary);
    margin-bottom: 8px;
    line-height: 1.4;
  }
  .req {
    color: var(--accent);
    margin-left: 2px;
  }
  .field input,
  .field textarea {
    background: var(--bg-tertiary);
    border: 1px solid var(--rule);
    border-radius: 2px;
    padding: 12px 14px;
    font-family: var(--font-serif);
    font-size: 16px;
    color: var(--tx);
    outline: none;
    resize: vertical;
    line-height: 1.5;
    width: 100%;
  }
  .field textarea {
    min-height: 140px;
  }
  .field input:focus,
  .field textarea:focus {
    border-color: var(--accent);
  }
  .field input::placeholder,
  .field textarea::placeholder {
    color: var(--tx-muted);
    font-style: italic;
  }
  .error {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--red);
    margin: 6px 0 0;
  }
  .hidden {
    display: none;
  }
  .honeypot {
    position: absolute;
    left: -9999px;
    height: 0;
    width: 0;
    overflow: hidden;
  }

  .submit-row {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    padding-top: 8px;
  }
  .submit {
    align-self: flex-start;
    padding: 10px 20px;
    background: var(--accent);
    color: var(--on-accent);
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 16px;
    border: 0;
    border-radius: 2px;
    cursor: pointer;
    letter-spacing: 0.005em;
  }
  .submit:hover {
    filter: brightness(0.95);
  }
  .submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
  .feedback {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 16px;
    margin: 0;
  }
  .feedback-success {
    color: var(--green);
  }
  .feedback-error {
    color: var(--red);
  }
</style>

<script
  is:inline
  define:vars={{
    required: t('contact.form.required'),
    invalidEmail: t('contact.form.invalidEmail'),
  }}
>
  function wireContactForm() {
    const form = document.getElementById('contact-form');
    if (!form || form.dataset.wired === '1') return;
    form.dataset.wired = '1';

    const submitLabel = form.querySelector('[data-submit-label]');
    const submittingLabel = form.querySelector('[data-submitting-label]');
    const successMsg = form.querySelector('[data-status="success"]');
    const errorMsg = form.querySelector('[data-status="error"]');
    const submitBtn = form.querySelector('button[type="submit"]');

    function setError(name, msg) {
      const target = form.querySelector(`[data-error-for="${name}"]`);
      const field = form.querySelector(`[name="${name}"]`);
      if (target) {
        target.textContent = msg || '';
        target.classList.toggle('hidden', !msg);
      }
      if (field) field.setAttribute('aria-invalid', msg ? 'true' : 'false');
    }

    function clearErrors() {
      ['name', 'email', 'message'].forEach((n) => setError(n, ''));
      successMsg?.classList.add('hidden');
      errorMsg?.classList.add('hidden');
    }

    function validate(data) {
      let ok = true;
      if (!data.name?.trim()) {
        setError('name', required);
        ok = false;
      }
      if (!data.email?.trim()) {
        setError('email', required);
        ok = false;
      } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(data.email.trim())) {
        setError('email', invalidEmail);
        ok = false;
      }
      if (!data.message?.trim() || data.message.trim().length < 10) {
        setError('message', required);
        ok = false;
      }
      return ok;
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      clearErrors();

      const fd = new FormData(form);
      const payload = Object.fromEntries(fd);
      if (!validate(payload)) return;

      submitBtn?.setAttribute('disabled', 'true');
      submitLabel?.classList.add('hidden');
      submittingLabel?.classList.remove('hidden');

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const body = await res.json().catch(() => ({ ok: false }));
        if (res.ok && body.ok) {
          successMsg?.classList.remove('hidden');
          form.reset();
        } else {
          errorMsg?.classList.remove('hidden');
        }
      } catch {
        errorMsg?.classList.remove('hidden');
      } finally {
        submitBtn?.removeAttribute('disabled');
        submitLabel?.classList.remove('hidden');
        submittingLabel?.classList.add('hidden');
      }
    });
  }

  wireContactForm();
  document.addEventListener('astro:page-load', wireContactForm);
</script>
