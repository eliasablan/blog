---
import type { Lang } from "@/i18n/ui";
import { useTranslations } from "@/i18n/utils";

interface Props {
    lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<form id="contact-form" class="flex flex-col gap-6" novalidate>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        <div class="flex flex-col">
            <label
                for="contact-name"
                class="mb-2 font-mono text-[11px] leading-[1.4] tracking-[0.12em] text-tx-secondary uppercase"
            >
                {t("contact.form.name")}
                <span class="ml-0.5 text-primary">*</span>
            </label>
            <input
                id="contact-name"
                name="name"
                type="text"
                required
                autocomplete="name"
                placeholder={t("contact.form.namePlaceholder")}
                class="w-full resize-y rounded-xs border border-rule bg-card px-3.5 py-3 font-serif text-base leading-normal text-foreground outline-none placeholder:text-tx-muted placeholder:italic focus:border-primary"
            />
            <p
                data-error-for="name"
                class="mt-1.5 hidden font-mono text-[11px] text-red"
            >
            </p>
        </div>
        <div class="flex flex-col">
            <label
                for="contact-email"
                class="mb-2 font-mono text-[11px] leading-[1.4] tracking-[0.12em] text-tx-secondary uppercase"
            >
                {t("contact.form.email")}
                <span class="ml-0.5 text-primary">*</span>
            </label>
            <input
                id="contact-email"
                name="email"
                type="email"
                required
                autocomplete="email"
                placeholder={t("contact.form.emailPlaceholder")}
                class="w-full resize-y rounded-xs border border-rule bg-card px-3.5 py-3 font-serif text-base leading-normal text-foreground outline-none placeholder:text-tx-muted placeholder:italic focus:border-primary"
            />
            <p
                data-error-for="email"
                class="mt-1.5 hidden font-mono text-[11px] text-red"
            >
            </p>
        </div>
    </div>

    <div class="flex flex-col">
        <label
            for="contact-subject"
            class="mb-2 font-mono text-[11px] leading-[1.4] tracking-[0.12em] text-tx-secondary uppercase"
            >{t("contact.form.subject")}</label
        >
        <input
            id="contact-subject"
            name="subject"
            type="text"
            placeholder={t("contact.form.subjectPlaceholder")}
            class="w-full resize-y rounded-xs border border-rule bg-card px-3.5 py-3 font-serif text-base leading-normal text-foreground outline-none placeholder:text-tx-muted placeholder:italic focus:border-primary"
        />
    </div>

    <div class="flex flex-col">
        <label
            for="contact-message"
            class="mb-2 font-mono text-[11px] leading-[1.4] tracking-[0.12em] text-tx-secondary uppercase"
        >
            {t("contact.form.message")}
            <span class="ml-0.5 text-primary">*</span>
        </label>
        <textarea
            id="contact-message"
            name="message"
            required
            rows="6"
            minlength="10"
            placeholder={t("contact.form.messagePlaceholder")}
            class="min-h-35 w-full resize-y rounded-xs border border-rule bg-card px-3.5 py-3 font-serif text-base leading-normal text-foreground outline-none placeholder:text-tx-muted placeholder:italic focus:border-primary"
        ></textarea>
        <p
            data-error-for="message"
            class="mt-1.5 hidden font-mono text-[11px] text-red"
        >
        </p>
    </div>

    {/* Honeypot */}
    <div
        aria-hidden="true"
        class="absolute -left-2499.75 h-0 w-0 overflow-hidden"
        tabindex="-1"
    >
        <label>
            Website (do not fill)
            <input
                type="text"
                name="website"
                tabindex="-1"
                autocomplete="off"
            />
        </label>
    </div>

    <div class="flex flex-wrap items-center gap-4 pt-2">
        <button
            type="submit"
            class="cursor-pointer self-start rounded-xs border-0 bg-primary px-5 py-2.5 font-serif text-base font-semibold tracking-[0.005em] text-primary-foreground hover:brightness-95 disabled:cursor-not-allowed disabled:opacity-60"
        >
            <span data-submit-label>{t("contact.form.submit")}</span>
            <span data-submitting-label class="hidden"
                >{t("contact.form.submitting")}</span
            >
        </button>
        <p
            data-status="success"
            class="m-0 hidden font-serif text-base italic text-green"
        >
            {t("contact.form.success")}
        </p>
        <p
            data-status="error"
            class="m-0 hidden font-serif text-base italic text-red"
        >
            {t("contact.form.error")}
        </p>
    </div>
</form>

<script
    is:inline
    define:vars={{
        required: t("contact.form.required"),
        invalidEmail: t("contact.form.invalidEmail"),
    }}
>
    function wireContactForm() {
        const form = document.getElementById("contact-form");
        if (!form || form.dataset.wired === "1") return;
        form.dataset.wired = "1";

        const submitLabel = form.querySelector("[data-submit-label]");
        const submittingLabel = form.querySelector("[data-submitting-label]");
        const successMsg = form.querySelector('[data-status="success"]');
        const errorMsg = form.querySelector('[data-status="error"]');
        const submitBtn = form.querySelector('button[type="submit"]');

        function setError(name, msg) {
            const target = form.querySelector(`[data-error-for="${name}"]`);
            const field = form.querySelector(`[name="${name}"]`);
            if (target) {
                target.textContent = msg || "";
                target.classList.toggle("hidden", !msg);
            }
            if (field)
                field.setAttribute("aria-invalid", msg ? "true" : "false");
        }

        function clearErrors() {
            ["name", "email", "message"].forEach((n) => setError(n, ""));
            successMsg?.classList.add("hidden");
            errorMsg?.classList.add("hidden");
        }

        function validate(data) {
            let ok = true;
            if (!data.name?.trim()) {
                setError("name", required);
                ok = false;
            }
            if (!data.email?.trim()) {
                setError("email", required);
                ok = false;
            } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(data.email.trim())) {
                setError("email", invalidEmail);
                ok = false;
            }
            if (!data.message?.trim() || data.message.trim().length < 10) {
                setError("message", required);
                ok = false;
            }
            return ok;
        }

        form.addEventListener("submit", async (e) => {
            e.preventDefault();
            clearErrors();

            const fd = new FormData(form);
            const payload = Object.fromEntries(fd);
            if (!validate(payload)) return;

            submitBtn?.setAttribute("disabled", "true");
            submitLabel?.classList.add("hidden");
            submittingLabel?.classList.remove("hidden");

            try {
                const res = await fetch("/api/contact", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(payload),
                });
                const body = await res.json().catch(() => ({ ok: false }));
                if (res.ok && body.ok) {
                    successMsg?.classList.remove("hidden");
                    form.reset();
                } else {
                    errorMsg?.classList.remove("hidden");
                }
            } catch {
                errorMsg?.classList.remove("hidden");
            } finally {
                submitBtn?.removeAttribute("disabled");
                submitLabel?.classList.remove("hidden");
                submittingLabel?.classList.add("hidden");
            }
        });
    }

    wireContactForm();
    document.addEventListener("astro:page-load", wireContactForm);
</script>
