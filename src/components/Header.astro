---
import type { Lang } from '@/i18n/ui';
import { useTranslations } from '@/i18n/utils';
import { sectionPath } from '@/i18n/routes';
import LanguageSwitcher from '@/components/LanguageSwitcher.astro';
import ThemeToggle from '@/components/ThemeToggle.astro';

interface Props {
  lang: Lang;
  /** Explicit URL of the translated counterpart (for entry pages). */
  altLangHref?: string;
  /** When false, switcher renders disabled (entry has no translation in target lang). */
  altLangAvailable?: boolean;
}

const { lang, altLangHref, altLangAvailable = true } = Astro.props;
const t = useTranslations(lang);

const links = [
  { href: `/${lang}/`, label: t('nav.home') },
  { href: sectionPath(lang, 'blog'), label: t('nav.blog') },
  { href: sectionPath(lang, 'portfolio'), label: t('nav.portfolio') },
];
---

<header class="sticky top-0 z-40 w-full border-b border-border bg-background/80 backdrop-blur">
  <div class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-4 py-3">
    <a
      href={`/${lang}/`}
      class="font-mono text-sm font-semibold tracking-tight hover:text-primary"
    >
      eliasablan.dev
    </a>

    <nav class="flex items-center gap-1 text-sm">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="rounded-md px-3 py-1.5 text-muted-foreground transition-colors hover:bg-accent hover:text-foreground"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-1">
      <LanguageSwitcher lang={lang} altUrl={altLangHref} available={altLangAvailable} />
      <ThemeToggle lang={lang} />
    </div>
  </div>
</header>
