---
import type { Lang } from "@/i18n/ui";
import { useTranslations } from "@/i18n/utils";
import { sectionPath } from "@/i18n/routes";
import LanguageSwitcher from "@/components/LanguageSwitcher.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";

interface Props {
  lang: Lang;
  /** Explicit URL of the translated counterpart (for entry pages). */
  altLangHref?: string;
  /** When false, switcher renders disabled (entry has no translation in target lang). */
  altLangAvailable?: boolean;
}

const { lang, altLangHref, altLangAvailable = true } = Astro.props;
const t = useTranslations(lang);

const links = [
  { href: `/${lang}/`, label: t("nav.home") },
  { href: sectionPath(lang, "blog"), label: t("nav.blog") },
  { href: sectionPath(lang, "portfolio"), label: t("nav.portfolio") },
];
---

<header
  class="sticky top-0 z-50 flex items-center justify-between gap-4 border-b border-rule bg-background/92 px-5 py-3.5 backdrop-blur-[10px] [view-transition-name:site-header] sm:px-8"
>
  <a
    href={`/${lang}/`}
    class="group inline-flex items-center gap-2.5 font-mono text-xs font-medium tracking-widest whitespace-nowrap text-foreground uppercase no-underline"
    data-brand-link
  >
    <span class="relative inline-flex size-1.5 items-center justify-center">
      <span
        class="pointer-events-none absolute top-1/2 left-1/2 size-3.5 -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary/20 opacity-0 group-hover:animate-ping group-hover:opacity-100"
        aria-hidden="true"></span>
      <span
        class="relative inline-block size-1.5 rounded-full bg-primary"
        aria-hidden="true"></span>
    </span>
    <span data-brand-scramble data-brand-text="ELIAS ABLAN">ELIAS ABLAN</span>
  </a>

  <nav class="hidden items-center gap-5.5 sm:inline-flex">
    {
      links.map((link) => (
        <a
          href={link.href}
          class="font-mono text-xs font-medium tracking-[0.08em] text-tx-secondary uppercase no-underline hover:text-foreground hover:decoration-transparent"
        >
          {link.label}
        </a>
      ))
    }
  </nav>

  <div class="flex items-center gap-2">
    <LanguageSwitcher
      lang={lang}
      altUrl={altLangHref}
      available={altLangAvailable}
    />
    <ThemeToggle lang={lang} />
  </div>
</header>

<script>
  const CYCLES_PER_LETTER = 3;
  const SHUFFLE_TIME = 35;
  const CHARS = "!@#$%^&*():{};|,.<>/?";

  function wireBrandScramble() {
    document.querySelectorAll("[data-brand-link]").forEach((link) => {
      if (!(link instanceof HTMLElement) || link.dataset.wired === "1") return;
      link.dataset.wired = "1";

      const textEl = link.querySelector("[data-brand-scramble]");
      if (!(textEl instanceof HTMLElement)) return;

      const brandTextEl = textEl;
      const text =
        brandTextEl.dataset.brandText ?? brandTextEl.textContent ?? "";
      let intervalId: number | undefined;

      function stopScramble() {
        if (intervalId) {
          window.clearInterval(intervalId);
          intervalId = undefined;
        }
        brandTextEl.textContent = text;
      }

      function scramble() {
        stopScramble();

        let pos = 0;
        intervalId = window.setInterval(() => {
          brandTextEl.textContent = text
            .split("")
            .map((_char, index) => {
              if (pos / CYCLES_PER_LETTER > index) return text[index];

              const randomCharIndex = Math.floor(Math.random() * CHARS.length);
              return CHARS[randomCharIndex];
            })
            .join("");

          pos++;

          if (pos >= text.length * CYCLES_PER_LETTER) {
            stopScramble();
          }
        }, SHUFFLE_TIME);
      }

      link.addEventListener("mouseenter", scramble);
      link.addEventListener("mouseleave", stopScramble);
    });
  }

  wireBrandScramble();
  document.addEventListener("astro:page-load", wireBrandScramble);
</script>
