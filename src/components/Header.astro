---
import type { Lang } from '@/i18n/ui';
import { useTranslations } from '@/i18n/utils';
import { sectionPath } from '@/i18n/routes';
import LanguageSwitcher from '@/components/LanguageSwitcher.astro';
import ThemeToggle from '@/components/ThemeToggle.astro';

interface Props {
  lang: Lang;
  /** Explicit URL of the translated counterpart (for entry pages). */
  altLangHref?: string;
  /** When false, switcher renders disabled (entry has no translation in target lang). */
  altLangAvailable?: boolean;
}

const { lang, altLangHref, altLangAvailable = true } = Astro.props;
const t = useTranslations(lang);

const links = [
  { href: `/${lang}/`, label: t('nav.home') },
  { href: sectionPath(lang, 'blog'), label: t('nav.blog') },
  { href: sectionPath(lang, 'portfolio'), label: t('nav.portfolio') },
];
---

<header
  class="topbar sticky top-0 z-50 flex items-center justify-between gap-4 border-b border-rule px-5 py-[14px] sm:px-8"
>
  <a href={`/${lang}/`} class="brand">
    <span class="dot" aria-hidden="true"></span>
    <span>ELIAS ABLAN</span>
  </a>

  <nav class="nav">
    {
      links.map((link) => (
        <a href={link.href} class="nav-link">
          {link.label}
        </a>
      ))
    }
  </nav>

  <div class="flex items-center gap-2">
    <LanguageSwitcher
      lang={lang}
      altUrl={altLangHref}
      available={altLangAvailable}
    />
    <ThemeToggle lang={lang} />
  </div>
</header>

<style>
  .topbar {
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--tx);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
    white-space: nowrap;
  }
  .brand .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    display: inline-block;
  }

  .nav {
    display: none;
    gap: 22px;
    align-items: center;
  }
  @media (min-width: 640px) {
    .nav {
      display: inline-flex;
    }
  }
  .nav-link {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 500;
    color: var(--tx-secondary);
    text-decoration: none;
  }
  .nav-link:hover {
    color: var(--tx);
    text-decoration-color: transparent;
  }
</style>
