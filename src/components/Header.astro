---
import type { Lang } from "@/i18n/ui";
import { useTranslations } from "@/i18n/utils";
import { sectionPath } from "@/i18n/routes";
import LanguageSwitcher from "@/components/LanguageSwitcher.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";

interface Props {
    lang: Lang;
    /** Explicit URL of the translated counterpart (for entry pages). */
    altLangHref?: string;
    /** When false, switcher renders disabled (entry has no translation in target lang). */
    altLangAvailable?: boolean;
}

const { lang, altLangHref, altLangAvailable = true } = Astro.props;
const t = useTranslations(lang);

const links = [
    { href: `/${lang}/`, label: t("nav.home") },
    { href: sectionPath(lang, "blog"), label: t("nav.blog") },
    { href: sectionPath(lang, "portfolio"), label: t("nav.portfolio") },
];
---

<header
    class="sticky top-0 z-50 flex items-center justify-between gap-4 border-b border-rule bg-background/92 px-5 py-3.5 backdrop-blur-[10px] [view-transition-name:site-header] sm:px-8"
>
    <a
        href={`/${lang}/`}
        class="inline-flex items-center gap-2.5 font-mono text-xs font-medium tracking-widest whitespace-nowrap text-foreground no-underline uppercase"
    >
        <span
            class="inline-block h-1.5 w-1.5 rounded-full bg-primary"
            aria-hidden="true"></span>
        <span>ELIAS ABLAN</span>
    </a>

    <nav class="hidden items-center gap-5.5 sm:inline-flex">
        {
            links.map((link) => (
                <a
                    href={link.href}
                    class="font-mono text-xs font-medium tracking-[0.08em] text-tx-secondary no-underline uppercase hover:text-foreground hover:decoration-transparent"
                >
                    {link.label}
                </a>
            ))
        }
    </nav>

    <div class="flex items-center gap-2">
        <LanguageSwitcher
            lang={lang}
            altUrl={altLangHref}
            available={altLangAvailable}
        />
        <ThemeToggle lang={lang} />
    </div>
</header>
