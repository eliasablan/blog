---
import type { Lang } from '@/i18n/ui';
import { useTranslations, altLangUrl } from '@/i18n/utils';

interface Props {
  lang: Lang;
  /** Optional explicit URL to switch to (used by entry pages with translationKey). */
  altUrl?: string;
  /** When false, render disabled (no translation in target lang). */
  available?: boolean;
}

const { lang, altUrl, available = true } = Astro.props;
const t = useTranslations(lang);
const target: Lang = lang === 'es' ? 'en' : 'es';
const href = altUrl ?? altLangUrl(Astro.url, target);
---

{
  available ? (
    <a
      href={href}
      class="lang-switch"
      aria-label={t('lang.switch')}
      hreflang={target}
    >
      {target}
    </a>
  ) : (
    <span
      class="lang-switch is-disabled"
      aria-disabled="true"
      title={t('lang.notAvailable')}
    >
      {target}
    </span>
  )
}

<style>
  .lang-switch {
    display: inline-flex;
    height: 36px;
    align-items: center;
    justify-content: center;
    padding: 0 10px;
    border-radius: 999px;
    border: 1px solid var(--rule);
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--tx-secondary);
    text-decoration: none;
  }
  .lang-switch:hover {
    color: var(--tx);
    border-color: var(--accent);
  }
  .lang-switch.is-disabled {
    color: var(--tx-muted);
    cursor: not-allowed;
    opacity: 0.5;
  }
</style>
